@inherits LayoutComponentBase
@inject ITabService TabService
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@using ERPGoEdition.Shared.Pages
@using ERPGoEdition.Shared.Dialogs
@using Microsoft.AspNetCore.Components.Authorization
@using Blazored.LocalStorage

@inject AuthenticationStateProvider AuthStateProvider
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">ERP Go Edition</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(isFullscreen ? Icons.Material.Filled.FullscreenExit : Icons.Material.Filled.Fullscreen)" 
                       Color="Color.Inherit" 
                       OnClick="ToggleFullscreen"
                       Title="@(isFullscreen ? "Exit Fullscreen" : "Enter Fullscreen")" />
        <MudMenu Direction="Direction.Left" OffsetX="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.Person" />
                </MudAvatar>
            </ActivatorContent>
            <ChildContent>
                <div class="pa-4 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Style="font-size: 64px;" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">@UserName</MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">@UserRole</MudText>
                    <MudDivider Class="mb-2" />
                    <MudButton StartIcon="@Icons.Material.Filled.Settings" FullWidth="true" OnClick="@OpenUserSettingsTab">User Settings</MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Logout" Color="Color.Error" FullWidth="true" Class="mt-1" OnClick="@Logout">Sign Out</MudButton>
                </div>
            </ChildContent>
        </MudMenu>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="@DrawerVariant.Mini" OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
        @if (TabService.Tabs.Any())
        {
             <MudTabs @bind-ActivePanelIndex="UserActiveIndex" 
                      KeepPanelsAlive="true" 
                      Class="erp-tabs"
                      Position="Position.Top"
                      PanelClass="erp-tab-content">
                @foreach (var tab in TabService.Tabs)
                {
                    <MudTabPanel @key="@tab.Id" ID="@tab.Id">
                        <TabContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                <MudText Typo="Typo.body2">@tab.Title</MudText>
                                @if (tab.IsClosable)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                                   Size="Size.Small" 
                                                   OnClick="@(() => CloseTabById(tab.Id))" />
                                }
                            </MudStack>
                        </TabContent>
                        <ChildContent>
                            @tab.Content
                        </ChildContent>
                    </MudTabPanel>
                }
            </MudTabs>
        }
        else
        {
             <div class="px-4 py-6">
                <MudAlert Severity="Severity.Info">Select an item from the menu to open a tab.</MudAlert>
                @Body
             </div>
        }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool isFullscreen = false;
    private DotNetObjectReference<MainLayout>? _objRef;
    
    // Auth State
    string UserName = "User";
    string UserRole = "Guest";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            UserName = user.Identity.Name ?? "User";
            UserRole = user.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
        }
        
        TabService.OnChange += HandleTabChange;
        if (!TabService.Tabs.Any())
        {
             // Add dashboard but don't force a StateHasChanged yet as we are initializing
            TabService.AddTab("Dashboard", builder =>
            {
                builder.OpenComponent(0, typeof(Home));
                builder.CloseComponent();
            }, isClosable: false);
        }
        UpdateActiveIndexFromService();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("eval", @"
                window.registerSettingsShortcut = (dotNetHelper) => {
                    document.addEventListener('keydown', function(e) {
                        if (e.ctrlKey && (e.key === 'p' || e.key === 'P')) {
                            e.preventDefault();
                            dotNetHelper.invokeMethodAsync('OpenSettingsDialog');
                        }
                    });
                };
            ");
            await JSRuntime.InvokeVoidAsync("registerSettingsShortcut", _objRef);
        }
    }

    [JSInvokable]
    public async Task OpenSettingsDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        DialogService.Show<SettingsDialog>("Application Settings", options);
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    async Task ToggleFullscreen()
    {
        try
        {
            isFullscreen = await JSRuntime.InvokeAsync<bool>("fullscreenHelper.toggleFullscreen");
            StateHasChanged();
        }
        catch (Exception)
        {
            // Fullscreen API might not be available (e.g., in some contexts)
            // Silently fail
        }
    }
    
    int userActiveIndex;
    
    // Sync property for binding
    int UserActiveIndex
    {
        get => userActiveIndex;
        set
        {
            if (userActiveIndex != value)
            {
                userActiveIndex = value;
                OnActivePanelIndexChanged(value);
            }
        }
    }
    
    void OpenUserSettingsTab()
    {
        TabService.AddTab("User Settings", builder => {
            builder.OpenComponent(0, typeof(UserSettings));
            builder.CloseComponent();
        });
    }

    async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        if (AuthStateProvider is CustomAuthStateProvider customAuth)
        {
            customAuth.MarkUserAsLoggedOut();
        }
        Navigation.NavigateTo("/login", true);
    }
    
    public void Dispose()
    {
        _objRef?.Dispose();
        TabService.OnChange -= HandleTabChange;
    }

    private void HandleTabChange()
    {
        UpdateActiveIndexFromService();
        InvokeAsync(StateHasChanged);
    }
    
    void UpdateActiveIndexFromService()
    {
        var activeTab = TabService.Tabs.FirstOrDefault(t => t.IsActive);
        if (activeTab != null)
        {
            userActiveIndex = TabService.Tabs.IndexOf(activeTab);
        }
        else
        {
            userActiveIndex = 0;
        }
    }

    void OnActivePanelIndexChanged(int index)
    {
        if (index >= 0 && index < TabService.Tabs.Count)
        {
             var tab = TabService.Tabs[index];
             // Only activate if different to avoid loops
             if (!tab.IsActive)
             {
                 TabService.ActivateTab(tab.Id);
             }
        }
    }

    void CloseTabById(string id)
    {
        TabService.CloseTab(id);
    }
}
