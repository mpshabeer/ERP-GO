@page "/supplier-master"
@using ERPGOAPPLICATION.Interfaces
@using ERPGODomain.Entities
@inject ISupplierService SupplierService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h5" GutterBottom="true">Supplier Master</MudText>

<MudGrid>
    <!-- Form Section -->
    <MudItem xs="12" md="5">
        <MudCard Elevation="25">
             <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@((currentSupplier.Id == 0) ? "Add New Supplier" : "Edit Supplier")</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudForm @ref="form" @bind-IsValid="@success">
                    <MudGrid Class="mt-0">
                        <MudItem xs="8">
                            <MudTextField T="string" Label="Name" @bind-Value="currentSupplier.Name" Required="true" RequiredError="Name is required." Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField T="string" Label="Code" @bind-Value="currentSupplier.Code" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        
                        <MudItem xs="6">
                            <MudTextField T="string" Label="Mobile" @bind-Value="currentSupplier.Mobile" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField T="string" Label="Email" @bind-Value="currentSupplier.Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField T="string" Label="Contact Person" @bind-Value="currentSupplier.ContactPerson" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        
                        <MudItem xs="6">
                            <MudTextField T="string" Label="Tax Number" @bind-Value="currentSupplier.TaxNumber" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                         <MudItem xs="12">
                            <MudTextField T="string" Label="Address" @bind-Value="currentSupplier.Address" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                        </MudItem>

                        <MudItem xs="6">
                            <MudTextField T="string" Label="City" @bind-Value="currentSupplier.City" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField T="string" Label="Country" @bind-Value="currentSupplier.Country" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudCheckBox T="bool" Label="Active" @bind-Value="currentSupplier.IsActive" Color="Color.Success" />
                        </MudItem>
                    </MudGrid>
                </MudForm>
            </MudCardContent>
            <MudCardActions>
                 <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await Save())" ButtonType="ButtonType.Button" Disabled="@_isProcessing" Class="ml-2">
                     @if (_isProcessing)
                     {
                         <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                         <MudText Class="ms-2">Processing</MudText>
                     }
                     else
                     {
                         <MudText>@((currentSupplier.Id == 0) ? "Save" : "Update")</MudText>
                     }
                 </MudButton>
                 <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Reset" Class="ml-2">Reset</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <!-- Grid Section -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="25">
             <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Supplier List</MudText>
                </CardHeaderContent>
                 <CardHeaderActions>
                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                 </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudTable Items="@Suppliers" Hover="true" Striped="true" Bordered="true" Dense="true" Filter="new Func<Supplier,bool>(FilterFunc)" OnRowClick="@(args => Edit(args.Item))" T="Supplier">
                    <HeaderContent>
                        <MudTh>Code</MudTh>
                        <MudTh>Name</MudTh>
                        <MudTh>Mobile</MudTh>
                        <MudTh>Contact Person</MudTh>
                        <MudTh>Active</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Code">@context.Code</MudTd>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="Mobile">@context.Mobile</MudTd>
                        <MudTd DataLabel="Contact Person">@context.ContactPerson</MudTd>
                        <MudTd DataLabel="Active">
                            <MudIcon Icon="@(context.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small" />
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@((e) => Delete(context.Id))" Size="Size.Small" Color="Color.Error" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private List<Supplier> Suppliers = new List<Supplier>();
    private Supplier currentSupplier = new Supplier { IsActive = true };
    private string searchString = "";
    private bool success;
    private MudForm form;
    private bool _isProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try 
        {
            Suppliers = await SupplierService.GetAllSuppliersAsync();
        }
        catch (Exception ex)
        {
             Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    private async Task Save()
    {
        form.Validate();
        if (!success) return;

        _isProcessing = true;
        
        try
        {
            if (currentSupplier.Id == 0)
            {
                await SupplierService.AddSupplierAsync(currentSupplier);
                Snackbar.Add("Supplier saved successfully", Severity.Success);
            }
            else
            {
                await SupplierService.UpdateSupplierAsync(currentSupplier);
                Snackbar.Add("Supplier updated successfully", Severity.Success);
            }
            
            await LoadData();
            Reset();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving supplier: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void Edit(Supplier supplier)
    {
        // Simple clone for editing
        currentSupplier = new Supplier
        {
            Id = supplier.Id,
            Name = supplier.Name,
            Code = supplier.Code,
            Address = supplier.Address,
            City = supplier.City,
            Country = supplier.Country,
            Mobile = supplier.Mobile,
            Email = supplier.Email,
            TaxNumber = supplier.TaxNumber,
            ContactPerson = supplier.ContactPerson,
            IsActive = supplier.IsActive
        };
        form.ResetValidation();
    }

    private async Task Delete(int id)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning", 
            "Deleting can not be undone!", 
            yesText:"Delete!", cancelText:"Cancel");

        if (result == true)
        {
            await SupplierService.DeleteSupplierAsync(id);
            await LoadData();
            Snackbar.Add("Supplier deleted", Severity.Success);
            if (currentSupplier.Id == id) Reset();
        }
    }

    private void Reset()
    {
        currentSupplier = new Supplier { IsActive = true };
        form.ResetValidation();
    }

    private bool FilterFunc(Supplier supplier)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (supplier.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (supplier.Code?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (supplier.Mobile?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }
}
