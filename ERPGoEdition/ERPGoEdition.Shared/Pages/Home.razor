@code {
    [Inject] ITabService TabService { get; set; } = default!;

    // ─── Loading state ───
    private bool _loading = true;

    // ─── KPI Values ───
    private decimal _todaySalesTotal = 0;
    private int _todaySalesCount = 0;
    private decimal _todayPurchasesTotal = 0;
    private int _todayPurchasesCount = 0;
    private decimal _monthSalesTotal = 0;
    private int _monthSalesCount = 0;
    private decimal _monthPurchasesTotal = 0;
    private int _monthPurchasesCount = 0;
    private int _totalItems = 0;
    private decimal _grossProfit = 0;

    // ─── Table Data ───
    private List<ERPGODomain.Entities.SalesInvoice> _recentSales = new();
    private List<Purchase> _recentPurchases = new();
    private List<ItemOpeningStock> _topStockItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var today = DateTime.Today;
            var monthStart = new DateTime(today.Year, today.Month, 1);
            var monthEnd = today;

            // Run all queries in parallel for speed
            var salesMonthTask = SalesService.GetInvoicesAsync(new InvoiceSearchRequest
            {
                DateFrom = monthStart,
                DateTo = monthEnd.AddDays(1),
                Page = 1,
                PageSize = 200
            });

            var purchasesMonthTask = PurchaseService.GetPurchasesAsync(new PurchaseSearchRequest
            {
                DateFrom = monthStart,
                DateTo = monthEnd.AddDays(1),
                Page = 1,
                PageSize = 200
            });

            var itemsTask = ItemService.GetAllItemsAsync();
            var stockTask = StockService.GetItemOpeningStocks();

            await Task.WhenAll(salesMonthTask, purchasesMonthTask, itemsTask, stockTask);

            // ─ Sales KPIs ─
            var monthlySales = salesMonthTask.Result?.Items ?? new List<ERPGODomain.Entities.SalesInvoice>();
            _monthSalesTotal = monthlySales.Sum(x => x.TotalAmount);
            _monthSalesCount = monthlySales.Count;

            var todaySales = monthlySales.Where(x => x.Date.Date == today).ToList();
            _todaySalesTotal = todaySales.Sum(x => x.TotalAmount);
            _todaySalesCount = todaySales.Count;

            _recentSales = monthlySales
                .OrderByDescending(x => x.Date)
                .Take(5)
                .ToList();

            // ─ Purchase KPIs ─
            var monthlyPurchases = purchasesMonthTask.Result?.Items ?? new List<Purchase>();
            _monthPurchasesTotal = monthlyPurchases.Sum(x => x.TotalAmount);
            _monthPurchasesCount = monthlyPurchases.Count;

            var todayPurchases = monthlyPurchases.Where(x => x.Date.Date == today).ToList();
            _todayPurchasesTotal = todayPurchases.Sum(x => x.TotalAmount);
            _todayPurchasesCount = todayPurchases.Count;

            _recentPurchases = monthlyPurchases
                .OrderByDescending(x => x.Date)
                .Take(5)
                .ToList();

            // ─ Gross Profit ─
            _grossProfit = _monthSalesTotal - _monthPurchasesTotal;

            // ─ Items ─
            _totalItems = itemsTask.Result?.Count ?? 0;

            // ─ Stock Snapshot ─
            _topStockItems = (stockTask.Result ?? new List<ItemOpeningStock>())
                .OrderByDescending(x => x.TotalValue)
                .Take(6)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Dashboard load error: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenTab(string title, Type componentType)
    {
        TabService.AddTab(title, builder =>
        {
            builder.OpenComponent(0, componentType);
            builder.CloseComponent();
        });
    }
}
