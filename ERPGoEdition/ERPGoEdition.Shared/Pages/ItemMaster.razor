@page "/item-master"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using ERPGOAPPLICATION.Interfaces
@using ERPGODomain.Entities
@inject IItemService ItemService
@inject IUnitService UnitService
@inject ICategoryService CategoryService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using ERPGOAPPLICATION.Interfaces
@inject IAppSettingsService AppSettingsService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2" Style="height: calc(100vh - 80px); overflow: hidden;">
    <MudGrid Spacing="2" Class="h-100">
        <!-- LEFT SIDEBAR: LIST -->
        <MudItem xs="12" md="3" Class="d-flex flex-column h-100 pr-2" Style="border-right: 1px solid #e0e0e0;">
            <!-- Valid Toolbar -->
             <MudPaper Elevation="0" Class="pa-2 mb-2 d-flex align-center gap-2">
                 <MudTextField @bind-Value="searchString" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" OnKeyUp="FilterItems" FullWidth="true"/>
                 <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadData" Size="Size.Small"/>
             </MudPaper>
            
            <MudPaper Elevation="0" Class="flex-grow-1 overflow-auto">
                <MudList T="Item" Clickable="true" SelectedValue="selectedItem" SelectedValueChanged="OnItemSelected" Dense="true" DisablePadding="true">
                    @foreach (var item in FilteredItems)
                    {
                        <MudListItem Value="@item" Class="py-2 border-bottom">
                            <div class="d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.subtitle2">@item.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.ItemCode</MudText>
                                </div>
                                <div class="d-flex flex-column align-end">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(item.CurrentStock > 0 ? Color.Success : Color.Warning)">@item.CurrentStock.ToString("N0")</MudChip>
                                    @if (!item.IsActive)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined" Class="mt-1" Style="font-size: 8px; height: 16px;">Inactive</MudChip>
                                    }
                                </div>
                            </div>
                        </MudListItem>
                    }
                    @if (!FilteredItems.Any())
                    {
                         <MudText Typo="Typo.caption" Class="pa-4 d-block text-center">No items found.</MudText>
                    }
                </MudList>
            </MudPaper>
            
             <MudPaper Elevation="0" Class="pa-2 mt-2 border-top">
                 <MudSwitch @bind-Value="_showInactive" Label="Show Inactive" Color="Color.Error" Size="Size.Small" T="bool" />
             </MudPaper>
        </MudItem>

        <!-- RIGHT MAIN CONTENT: FORM -->
        <MudItem xs="12" md="9" Class="h-100 d-flex flex-column">
            <!-- Action Bar (Sticky) -->
            <MudPaper Elevation="2" Class="pa-2 mb-3 d-flex align-center gap-2 rounded-lg z-10">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNew">New Item</MudButton>
                <MudSpacer />
                @if (currentItem.Id > 0)
                {
                     @if(currentItem.IsActive)
                     {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="@(() => Delete(currentItem.Id))">Deactivate</MudButton>
                     }
                     else
                     {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Restore" OnClick="@(() => Restore(currentItem))">Restore</MudButton>
                     }
                }
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Save" OnClick="Save" Disabled="@_isProcessing">
                    @if (_isProcessing) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/> <span class="ml-2">Saving...</span> } else { <span>Save Changes</span> }
                </MudButton>
            </MudPaper>

            <!-- Scrollable Form Content (Single Page View) -->
            <MudItem Class="flex-grow-1 overflow-auto" Style="max-height: calc(100vh - 160px);">
                <MudForm @ref="form" @bind-IsValid="@success">
                    <MudPaper Elevation="2" Class="pa-2 rounded-lg">
                        <MudGrid Spacing="1">
                            <!-- Row 1: Identifiers -->
                            <MudItem xs="6">
                                <MudTextField T="string" Label="Item Name" @bind-Value="currentItem.Name" Required="true" RequiredError="Item name is required" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" Style="font-weight: bold;" />
                            </MudItem>
                            <MudItem xs="3">
                                <MudTextField T="string" Label="Code" @bind-Value="currentItem.ItemCode" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" />
                            </MudItem>
                            <MudItem xs="3">
                                <MudTextField T="string" Label="Barcode" @bind-Value="currentItem.Barcode" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.QrCodeScanner" />
                            </MudItem>

                            <!-- Row 2: Categorization & Units -->
                            <MudItem xs="3">
                                <MudSelect T="int?" Label="Category" Value="currentItem.CategoryId" ValueChanged="OnCategoryChanged" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" AnchorOrigin="Origin.BottomCenter" Clearable="true">
                                    @foreach (var cat in Categories)
                                    {
                                        <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="3">
                                <MudSelect T="int" Label="Base Unit" Value="currentItem.UnitId" ValueChanged="OnBaseUnitChanged" Required="true" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Value="0" Disabled="true">Unit</MudSelectItem>
                                    @foreach (var unit in Units.Where(u => u.IsActive || u.Id == currentItem.UnitId).DistinctBy(u => u.Id))
                                    {
                                        <MudSelectItem Value="@unit.Id">@unit.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="3">
                                <MudNumericField T="decimal" Label="Stock" @bind-Value="currentItem.CurrentStock" Format="N0" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" Disabled="@(currentItem.Id != 0)" HideSpinButtons="true" Style="text-align: right;" />
                            </MudItem>
                             <MudItem xs="3" Class="d-flex align-center mt-2">
                                <MudCheckBox T="bool" Label="Multi-Unit" Value="currentItem.IsMultiUnit" ValueChanged="@((bool v) => OnIsMultiUnitChanged(v))" Color="Color.Primary" Dense="true" Size="Size.Small" />
                            </MudItem>

                            <!-- Row 3: Pricing (Compact) -->
                            <MudItem xs="3">
                                <MudNumericField T="decimal" Label="Sales Rate" Value="currentItem.Rate" ValueChanged="OnSalesRateChanged" Format="N2" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" HideSpinButtons="true" Style="text-align: right;" />
                            </MudItem>
                            <MudItem xs="3">
                                <MudNumericField T="decimal" Label="Purchase Rate" Value="currentItem.PurchaseRate" ValueChanged="OnPurRateChanged" Format="N2" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" HideSpinButtons="true" Style="text-align: right;" />
                            </MudItem>
                            <MudItem xs="3">
                                <MudNumericField T="decimal" Label="Wholesale" Value="currentItem.WholesaleRate" ValueChanged="OnWholesaleRateChanged" Format="N2" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" HideSpinButtons="true" Style="text-align: right;" />
                            </MudItem>
                            <MudItem xs="3"></MudItem> <!-- Spacer for alignment -->

                            <!-- Row 4: GST & Taxes -->
                            <MudItem xs="3">
                                <MudTextField T="string" Label="HSN Code" @bind-Value="currentItem.HSNCode" MaxLength="8" Pattern="[0-9]*" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" HelperText="Numeric only" />
                            </MudItem>
                            <MudItem xs="3">
                                <MudNumericField T="decimal" Label="GST %" @bind-Value="currentItem.GstPercent" Format="N2" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" HideSpinButtons="true" Min="0" Max="28" Disabled="@(!currentItem.IsGSTApplicable)"
                                                Adornment="Adornment.End" AdornmentText="%" Style="border-left: 3px solid #2E7D32; text-align: right;" />
                            </MudItem>
                            <MudItem xs="3" Class="d-flex align-center mt-2">
                                <MudCheckBox T="bool" Label="GST Applicable" Value="currentItem.IsGSTApplicable" ValueChanged="OnGstApplicableChanged" Color="Color.Primary" Dense="true" Size="Size.Small" />
                            </MudItem>
                            <MudItem xs="3">
                                <MudSelect T="string" Label="Tax Type" @bind-Value="currentItem.TaxType" Variant="Variant.Outlined" Margin="Margin.None" Dense="true" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Value="@("GST")">GST</MudSelectItem>
                                    <MudSelectItem Value="@("Exempt")">Exempt</MudSelectItem>
                                    <MudSelectItem Value="@("Nil Rated")">Nil Rated</MudSelectItem>
                                    <MudSelectItem Value="@("Non-GST")">Non-GST</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <!-- Row 4: Multi-Unit Grid (If Enabled) -->
                            @if (currentItem.IsMultiUnit)
                            {
                                <MudItem xs="12">
                                    <MudStack Row="true" Class="my-1 align-center">
                                         <MudText Typo="Typo.subtitle2"><b>Packings / Units</b></MudText>
                                         <MudSpacer />
                                         <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => AddUnitRow())" Color="Color.Secondary" Class="py-0">Add Packing</MudButton>
                                    </MudStack>
                                    
                                    <MudTable Items="@currentItem.ItemUnits" Hover="true" Dense="true" Bordered="true" Striped="true" Elevation="0" Outlined="true" Class="mt-1">
                                        <HeaderContent>
                                            <MudTh Style="width: 25%; padding: 4px;">Unit</MudTh>
                                            <MudTh Style="width: 20%; padding: 4px; text-align:right;">Qty/Base</MudTh>
                                            <MudTh Style="width: 20%; padding: 4px; text-align:right;">Sales Rate</MudTh>
                                            <MudTh Style="width: 20%; padding: 4px; text-align:right;">Pur Rate</MudTh>
                                            <MudTh Style="width: 15%; padding: 4px; text-align:center;">Action</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            @{
                                                var isBaseRow = context.UnitId == currentItem.UnitId || (currentItem.ItemUnits.ToList().IndexOf(context) == 0);
                                                // If it is the base row, forcibly sync to the primary unit so visually it makes sense
                                                if (isBaseRow && context.UnitId != currentItem.UnitId) { context.UnitId = currentItem.UnitId; }
                                            }
                                            <MudTd DataLabel="Unit" Style="width: 25%; padding: 2px 4px; border-right: 1px solid #e0e0e0;">
                                                @if (isBaseRow)
                                                {
                                                    <MudText Style="font-size:0.8rem; font-weight:600;">@(Units.FirstOrDefault(u => u.Id == context.UnitId)?.Name ?? "—") <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="font-size:0.65rem; height:16px; padding:0 4px;">Base</MudChip></MudText>
                                                }
                                                else
                                                {
                                                    <MudSelect T="int" Value="context.UnitId" ValueChanged="@((int v) => OnItemUnitChanged(context, v))" Margin="Margin.None" Variant="Variant.Text" Style="font-size: 0.8rem" DisableUnderLine="true" Dense="true">
                                                        @foreach (var unit in Units.Where(u => u.Id == context.UnitId || (u.IsActive && !currentItem.ItemUnits.Any(iu => iu.UnitId == u.Id))).DistinctBy(u => u.Id))
                                                        {
                                                            <MudSelectItem Value="@unit.Id">@unit.Name</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Qty/Base" Style="width: 20%; padding: 2px; text-align:right; border-right: 1px solid #e0e0e0;">
                                                @if (isBaseRow) {
                                                    <MudNumericField T="decimal" Value="1m" Margin="Margin.None" Variant="Variant.Text" DisableUnderLine="true" HideSpinButtons="true" Disabled="true" Style="text-align:right;" />
                                                } else {
                                                    <MudNumericField @bind-Value="context.QtyPerBaseUnit" Margin="Margin.None" Variant="Variant.Text" DisableUnderLine="true" HideSpinButtons="true" Style="text-align:right;" />
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Sales Rate" Style="width: 20%; padding: 2px; text-align:right; border-right: 1px solid #e0e0e0;">
                                                @if (isBaseRow) {
                                                    <MudNumericField T="decimal" Value="currentItem.Rate" ValueChanged="OnSalesRateChanged" Margin="Margin.None" Variant="Variant.Text" Format="N2" DisableUnderLine="true" HideSpinButtons="true" Style="text-align:right;" />
                                                } else {
                                                    <MudNumericField @bind-Value="context.Rate" Margin="Margin.None" Variant="Variant.Text" Format="N2" DisableUnderLine="true" HideSpinButtons="true" Style="text-align:right;" />
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Pur Rate" Style="width: 20%; padding: 2px; text-align:right; border-right: 1px solid #e0e0e0;">
                                                @if (isBaseRow) {
                                                    <MudNumericField T="decimal" Value="currentItem.PurchaseRate" ValueChanged="OnPurRateChanged" Margin="Margin.None" Variant="Variant.Text" Format="N2" DisableUnderLine="true" HideSpinButtons="true" Style="text-align:right;" />
                                                } else {
                                                    <MudNumericField @bind-Value="context.PurchaseRate" Margin="Margin.None" Variant="Variant.Text" Format="N2" DisableUnderLine="true" HideSpinButtons="true" Style="text-align:right;" />
                                                }
                                            </MudTd>
                                            <MudTd Style="width: 15%; padding: 0px; text-align:center;">
                                                @if (!isBaseRow)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveUnitRow(context))" Size="Size.Small" Color="Color.Error" />
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                </MudForm>
            </MudItem>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<Item> Items = new List<Item>();
    private List<Item> FilteredItems = new List<Item>();
    private List<Unit> Units = new List<Unit>();
    private List<Category> Categories = new List<Category>();
    
    private Item currentItem = new Item { IsActive = true };
    private Item selectedItem; // For the List selection
    
    private string searchString = "";
    private bool success;
    private MudForm form;
    private bool _isProcessing = false;
    private bool _showInactive = false;
    
    // Multi-Unit Edit Table Variables
    private ItemUnit selectedItemUnit;
    private ItemUnit elementBeforeEdit;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await CreateNew(); // Auto-open New Item on load
    }

    private async Task LoadData()
    {
        // 1. Load Items
        try 
        {
            Items = await ItemService.GetAllItemsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading Items: {ex.Message}", Severity.Error);
            Items = new List<Item>();
        }

        // 2. Load Units
        try
        {
            Units = await UnitService.GetAllUnitsIncludeInactiveAsync();
        }
        catch (Exception ex)
        {
             Console.WriteLine($"Error loading Units: {ex.Message}");
             Units = new List<Unit>(); 
        }

        // 3. Load Categories
        try 
        {
            Categories = await CategoryService.GetAllCategoriesAsync();
        }
        catch (Exception)
        {
            Categories = new List<Category>();
        }
        
        FilterItems(); 
    }

    private void OnGstApplicableChanged(bool isApplicable)
    {
        currentItem.IsGSTApplicable = isApplicable;
        if (!isApplicable)
        {
            currentItem.GstPercent = 0;
            if (currentItem.TaxType == "GST")
            {
                currentItem.TaxType = "Non-GST";
            }
        }
    }
    
    private void FilterItems()
    {
        var temp = Items.AsEnumerable();
        
        if (!_showInactive)
        {
            temp = temp.Where(x => x.IsActive);
        }
        
        if (!string.IsNullOrWhiteSpace(searchString))
        {
            temp = temp.Where(item => 
                (item.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (item.ItemCode?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (item.Barcode?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            );
        }
        
        FilteredItems = temp.OrderBy(i => i.Name).ToList();
        StateHasChanged();
    }
    
    // Helper to trigger logic when list selection changes
    private async Task OnItemSelected(Item item)
    {
        if (item != null)
        {
            selectedItem = item;
            await Edit(item);
        }
    }

    private async Task OnCategoryChanged(int? categoryId)
    {
        currentItem.CategoryId = categoryId;
        
        // Auto-select Default Unit if set in Category
        if (categoryId.HasValue)
        {
            var cat = Categories.FirstOrDefault(c => c.Id == categoryId.Value);
            if (cat?.DefaultUnitId != null && cat.DefaultUnitId > 0)
            {
                OnBaseUnitChanged(cat.DefaultUnitId.Value);
            }
        }
    }

    private void OnBaseUnitChanged(int newUnitId)
    {
        currentItem.UnitId = newUnitId;
        
        if (currentItem.IsMultiUnit && currentItem.ItemUnits != null && currentItem.ItemUnits.Any())
        {
            var list = currentItem.ItemUnits.ToList();
            var baseRow = list.FirstOrDefault();
            if (baseRow != null)
            {
                baseRow.UnitId = newUnitId;
                baseRow.QtyPerBaseUnit = 1;
            }
        }
    }

    private void OnRateChanged(decimal newValue, string rateType)
    {
        if (rateType == "Sales") currentItem.Rate = newValue;
        else if (rateType == "Purchase") currentItem.PurchaseRate = newValue;
        else if (rateType == "Wholesale") currentItem.WholesaleRate = newValue;

        // If multi-unit, sync the first row explicitly just in case (though UI binding also handles it)
        if (currentItem.IsMultiUnit && currentItem.ItemUnits != null && currentItem.ItemUnits.Any())
        {
            var baseRow = currentItem.ItemUnits.First();
            if (rateType == "Sales") baseRow.Rate = newValue;
            else if (rateType == "Purchase") baseRow.PurchaseRate = newValue;
            else if (rateType == "Wholesale") baseRow.WholesaleRate = newValue;
        }
    }

    private void OnSalesRateChanged(decimal v) => OnRateChanged(v, "Sales");
    private void OnPurRateChanged(decimal v) => OnRateChanged(v, "Purchase");
    private void OnWholesaleRateChanged(decimal v) => OnRateChanged(v, "Wholesale");

    private async Task CreateNew()
    {
        try
        {
            selectedItem = null; // Deselect list
            
            var defaultUnit = Units.FirstOrDefault(u => u.IsActive && u.Name.Equals("PCS", StringComparison.OrdinalIgnoreCase)) 
                           ?? Units.FirstOrDefault(u => u.IsActive && u.Name.Equals("NOS", StringComparison.OrdinalIgnoreCase))
                           ?? Units.FirstOrDefault(u => u.IsActive);

            currentItem = new Item 
            { 
                Name = "",
                ItemCode = "",
                Barcode = "",
                IsActive = true, 
                CategoryId = null,
                ItemUnits = new List<ItemUnit>(),
                UnitId = defaultUnit?.Id ?? 0,
                CurrentStock = 0,
                Rate = 0,
                PurchaseRate = 0,
                WholesaleRate = 0,
                IsMultiUnit = false,
                HSNCode = null,
                GstPercent = 0,
                IsGSTApplicable = true,
                TaxType = "GST"
            };

            var settings = await AppSettingsService.GetSettingsAsync();
            if (settings.AutoGenerateItemCode)
            {
                currentItem.ItemCode = await ItemService.GetNextItemCodeAsync(settings.ItemCodePrefix, settings.ItemCodeStartNumber);
            }

            form?.ResetValidation();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error initializing item: {ex.Message}.", Severity.Error);
        }
    }

    private async Task Edit(Item item)
    {
        // Deep clone for editing
        currentItem = new Item 
        { 
            Id = item.Id, 
            Name = item.Name, 
            ItemCode = item.ItemCode,
            Barcode = item.Barcode,
            UnitId = item.UnitId,
            BaseUnit = item.BaseUnit,
            CategoryId = item.CategoryId, 
            Rate = item.Rate,
            PurchaseRate = item.PurchaseRate,
            WholesaleRate = item.WholesaleRate,
            HSNCode = item.HSNCode,
            IsGSTApplicable = item.IsGSTApplicable,
            TaxType = item.TaxType,
            GstPercent = item.GstPercent,
            IsMultiUnit = item.IsMultiUnit,
            IsActive = item.IsActive,
            CurrentStock = item.CurrentStock,
            ItemUnits = item.ItemUnits?.Select(iu => new ItemUnit 
            { 
                Id = iu.Id, 
                ItemId = iu.ItemId, 
                UnitId = iu.UnitId,
                Unit = iu.Unit, 
                Rate = iu.Rate, 
                PurchaseRate = iu.PurchaseRate,
                WholesaleRate = iu.WholesaleRate,
                QtyPerBaseUnit = iu.QtyPerBaseUnit
            }).ToList() ?? new List<ItemUnit>()
        };
        
        form?.ResetValidation();
    }

    private async Task Save()
    {
        form.Validate();
        if (!success) 
        {
            Snackbar.Add("Please fix validation errors.", Severity.Warning);
            return;
        }
        
        if (currentItem.UnitId == 0)
        {
            Snackbar.Add("Base Unit is required.", Severity.Warning);
            return;
        }

        _isProcessing = true;
        
        try
        {
            // FINAL SYNC BEFORE SAVE: Ensure Base Unit Row rules are strictly enforced
            if (currentItem.IsMultiUnit)
            {
                if (currentItem.ItemUnits == null) currentItem.ItemUnits = new List<ItemUnit>();
                var baseRow = currentItem.ItemUnits.FirstOrDefault(u => u.UnitId == currentItem.UnitId);
                if (baseRow == null && currentItem.ItemUnits.Any()) 
                {
                    baseRow = currentItem.ItemUnits.First();
                    baseRow.UnitId = currentItem.UnitId;
                }
                else if (baseRow == null)
                {
                    baseRow = new ItemUnit { UnitId = currentItem.UnitId };
                    var lst = currentItem.ItemUnits.ToList();
                    lst.Insert(0, baseRow);
                    currentItem.ItemUnits = lst;
                }

                baseRow.QtyPerBaseUnit = 1;
                baseRow.Rate = currentItem.Rate;
                baseRow.PurchaseRate = currentItem.PurchaseRate;
                baseRow.WholesaleRate = currentItem.WholesaleRate;
            }

            if (currentItem.Id == 0)
            {
                await ItemService.AddItemAsync(currentItem);
                Snackbar.Add("Item saved successfully", Severity.Success);
            }
            else
            {
                await ItemService.UpdateItemAsync(currentItem);
                Snackbar.Add("Item updated successfully", Severity.Success);
            }
            
            await LoadData(); 
            // Stay on the saved item or clear? ERPs usually toggle. 
            // Let's clear to "New" for rapid entry, OR stay on edit. 
            // User requested "load text box first", likely wants rapid entry.
            // But usually after save, you might want to edit. 
            // Let's switch to New for now or keep it. I'll keep it on the current item so they can verify.
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving item: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task Delete(int id)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Delete Item", 
            "Are you sure you want to deactivate this item?", 
            yesText:"Deactivate", cancelText:"Cancel");

        if (result == true)
        {
            await ItemService.DeleteItemAsync(id);
            await LoadData();
            await CreateNew(); // Reset to new after delete
            Snackbar.Add("Item deactivated", Severity.Success);
        }
    }
    
    private async Task Restore(Item item)
    {
        item.IsActive = true;
        try 
        {
             await ItemService.UpdateItemAsync(item);
             await LoadData();
             Snackbar.Add("Item restored successfully", Severity.Success);
        }
        catch(Exception ex)
        {
            Snackbar.Add($"Error restoring item: {ex.Message}", Severity.Error);
        }
    }

    // Multi-Unit Logic
    private void OnIsMultiUnitChanged(bool value)
    {
        currentItem.IsMultiUnit = value;
        if (value)
        {
            EnsureBaseUnitRow();
        }
    }

    private void EnsureBaseUnitRow()
    {
        if (currentItem.UnitId == 0) return;
        if (currentItem.ItemUnits == null) currentItem.ItemUnits = new List<ItemUnit>();
        
        // Remove any existing row that claims to be a base unit row but isn't
        var baseRows = currentItem.ItemUnits.Where(u => u.UnitId == currentItem.UnitId).ToList();
        if (!baseRows.Any())
        {
            var baseUnit = new ItemUnit
            {
                ItemId = currentItem.Id,
                UnitId = currentItem.UnitId,
                QtyPerBaseUnit = 1,
                Rate = currentItem.Rate,
                PurchaseRate = currentItem.PurchaseRate,
                WholesaleRate = currentItem.WholesaleRate
            };
            var list = currentItem.ItemUnits.ToList();
            list.Insert(0, baseUnit);
            currentItem.ItemUnits = list;
        }
        else
        {
            // Sync values to existing base row
            var baseRow = baseRows.First();
            baseRow.QtyPerBaseUnit = 1;
            baseRow.Rate = currentItem.Rate;
            baseRow.PurchaseRate = currentItem.PurchaseRate;
            baseRow.WholesaleRate = currentItem.WholesaleRate;
            
            // Ensure it's at index 0 (UX preference)
            var list = currentItem.ItemUnits.ToList();
            list.Remove(baseRow);
            list.Insert(0, baseRow);
            currentItem.ItemUnits = list;
        }
    }

    private void AddUnitRow()
    {
        if (currentItem.ItemUnits == null) currentItem.ItemUnits = new List<ItemUnit>();
        
        // Find first unit not yet used
        var usedUnitIds = currentItem.ItemUnits.Select(iu => iu.UnitId).ToHashSet();
        var nextUnit = Units.FirstOrDefault(u => u.IsActive && !usedUnitIds.Contains(u.Id));
        
        if (nextUnit == null)
        {
            Snackbar.Add("All available units have already been added.", Severity.Warning);
            return;
        }
        
        currentItem.ItemUnits.Add(new ItemUnit
        {
            ItemId = currentItem.Id,
            UnitId = nextUnit.Id,
            QtyPerBaseUnit = 1
        });
    }

    private void OnItemUnitChanged(ItemUnit row, int newUnitId)
    {
        // Prevent duplicate
        if (currentItem.ItemUnits.Any(iu => iu != row && iu.UnitId == newUnitId))
        {
            Snackbar.Add("This unit is already added. Each unit can only appear once.", Severity.Warning);
            return;
        }
        row.UnitId = newUnitId;
    }

    private void RemoveUnitRow(ItemUnit unit)
    {
        // Prevent removing base unit row (first row)
        if (currentItem.ItemUnits.ToList().IndexOf(unit) == 0 && unit.UnitId == currentItem.UnitId)
        {
            Snackbar.Add("The base unit row cannot be removed.", Severity.Warning);
            return;
        }
        currentItem.ItemUnits.Remove(unit);
    }
    
    private void BackupItem(object element)
    {
        var itemVal = (ItemUnit)element;
        elementBeforeEdit = new ItemUnit
        {
            UnitId = itemVal.UnitId,
            QtyPerBaseUnit = itemVal.QtyPerBaseUnit,
            Rate = itemVal.Rate,
            PurchaseRate = itemVal.PurchaseRate,
            WholesaleRate = itemVal.WholesaleRate
        };
    }

    private void ResetItemToOriginalValues(object element)
    {
        var item = (ItemUnit)element;
        var original = elementBeforeEdit;
        item.UnitId = original.UnitId;
        item.QtyPerBaseUnit = original.QtyPerBaseUnit;
        item.Rate = original.Rate;
        item.PurchaseRate = original.PurchaseRate;
        item.WholesaleRate = original.WholesaleRate;
    }
}
