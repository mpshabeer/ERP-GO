@page "/expenses"
@using ERPGOAPPLICATION.Interfaces
@using ERPGODomain.Entities
@using ERPGoEdition.Shared.Pages
@inject IVoucherService VoucherService
@inject ITabService TabService

<div class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h5" Color="Color.Primary"><b>Expenses</b></MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewEntry">New Expense</MudButton>
    </div>

    <MudTable Items="@_expenses" Dense="true" Hover="true" Bordered="true" Striped="true" Loading="@_isLoading">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Expense No</MudTh>
            <MudTh>Expense Account</MudTh>
            <MudTh>Paid From (Cash/Bank)</MudTh>
            <MudTh Style="text-align:right;">Amount</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Date.ToString("dd/MM/yyyy")</MudTd>
            <MudTd><b>@context.ExpenseNo</b></MudTd>
            <MudTd>@context.ExpenseAccount?.Name</MudTd>
            <MudTd>@context.CashBankAccount?.Name</MudTd>
            <MudTd Style="text-align:right; font-weight:bold; color: #E65100;">@context.Amount.ToString("N2")</MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    private List<Expense> _expenses = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        _expenses = await VoucherService.GetExpensesAsync();
        _isLoading = false;
    }

    private void OpenNewEntry()
    {
        TabService.AddTab("New Expense", builder => {
            builder.OpenComponent(0, typeof(ExpenseEntry));
            builder.CloseComponent();
        });
    }
}
