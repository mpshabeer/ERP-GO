@page "/payments"
@using ERPGOAPPLICATION.Interfaces
@using ERPGODomain.Entities
@using ERPGoEdition.Shared.Pages
@inject IVoucherService VoucherService
@inject ITabService TabService

<div class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h5" Color="Color.Primary"><b>Payments</b></MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewEntry">New Payment</MudButton>
    </div>

    <MudTable Items="@_payments" Dense="true" Hover="true" Bordered="true" Striped="true" Loading="@_isLoading">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Payment No</MudTh>
            <MudTh>Paid To</MudTh>
            <MudTh>Paid From (Cash/Bank)</MudTh>
            <MudTh Style="text-align:right;">Amount</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Date.ToString("dd/MM/yyyy")</MudTd>
            <MudTd><b>@context.PaymentNo</b></MudTd>
            <MudTd>@context.PartyAccount?.Name</MudTd>
            <MudTd>@context.CashBankAccount?.Name</MudTd>
            <MudTd Style="text-align:right; font-weight:bold; color: #D32F2F;">@context.Amount.ToString("N2")</MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    private List<Payment> _payments = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        _payments = await VoucherService.GetPaymentsAsync();
        _isLoading = false;
    }

    private void OpenNewEntry()
    {
        TabService.AddTab("New Payment", builder => {
            builder.OpenComponent(0, typeof(PaymentEntry));
            builder.CloseComponent();
        });
    }
}
