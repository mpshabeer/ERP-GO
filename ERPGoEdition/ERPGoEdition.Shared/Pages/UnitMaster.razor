@page "/unit-master"
@using ERPGOAPPLICATION.Interfaces
@using ERPGODomain.Entities
@inject IUnitService UnitService
@inject ISnackbar Snackbar

<PageTitle>Unit Master - ERP Go</PageTitle>

<div class="page-wrapper">
    <!-- Header -->
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight:700; color:#1565C0;">Unit Master</MudText>
            <MudText Typo="Typo.caption" Style="color:#78909C;">Manage measurement units and metadata</MudText>
        </div>
        <div class="d-flex gap-2">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="LoadUnits" Disabled="_isProcessing" Color="Color.Primary" Title="Refresh" />
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="main-grid">
        
        <!-- Left Pane: Data Entry -->
        <MudCard Elevation="3" Class="entry-card">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Primary" Size="Size.Medium">
                        <MudIcon Icon="@(currentUnit.Id == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">@(currentUnit.Id == 0 ? "New Unit" : "Edit Unit")</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudDivider />
            <MudCardContent>
                <MudForm @ref="form" @bind-IsValid="@success">
                    <MudTextField T="string" @ref="_codeField"
                                  Label="Unit Code (Symbol)" @bind-Value="currentUnit.Code" 
                                  Required="true" RequiredError="Code is required." 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  OnKeyDown="@(e => HandleKeyDown(e, _nameField))" />
                                  
                    <MudTextField T="string" @ref="_nameField" Class="mt-4"
                                  Label="Unit Name" @bind-Value="currentUnit.Name" 
                                  Required="true" RequiredError="Name is required." 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  OnKeyDown="@(e => HandleKeyDown(e, _decimalField))" />
                                  
                    <MudNumericField T="int" @ref="_decimalField" Class="mt-4"
                                     Label="Decimal Places" @bind-Value="currentUnit.DecimalPlaces" 
                                     Min="0" Max="4" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                     OnKeyDown="HandleDecimalKeyDown" />
                                     
                    <MudCheckBox T="bool" @ref="_activeCheck" Class="mt-3" Label="Active" @bind-Value="currentUnit.IsActive" Color="Color.Primary" />
                </MudForm>
            </MudCardContent>
            <MudDivider />
            <MudCardActions Class="pa-4 d-flex justify-end gap-2">
                 <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ResetAsync" Disabled="@_isProcessing">Clear</MudButton>
                 <MudButton @ref="_saveButton" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await Save())" Disabled="@_isProcessing">
                     @if (_isProcessing)
                     {
                         <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                         <MudText Class="ms-2">Wait</MudText>
                     }
                     else
                     {
                         <MudText>@(currentUnit.Id == 0 ? "Save Unit" : "Update Unit")</MudText>
                     }
                 </MudButton>
            </MudCardActions>
        </MudCard>

        <!-- Right Pane: Data List -->
        <MudCard Elevation="3" Class="list-card">
            <MudCardHeader>
                 <CardHeaderContent>
                     <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Units List</MudText>
                 </CardHeaderContent>
                 <CardHeaderActions>
                    <MudTextField @bind-Value="searchString" Placeholder="Search units..." Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Style="width:200px; margin-top:-8px;"></MudTextField>
                 </CardHeaderActions>
            </MudCardHeader>
            <MudDivider />
            <MudCardContent Class="pa-0">
                <MudTable Items="@Units" Hover="true" Dense="true" Elevation="0" 
                          Filter="new Func<Unit, bool>(FilterFunc)" OnRowClick="@(args => Edit(args.Item))" T="Unit" >
                    <HeaderContent>
                        <MudTh Style="font-weight:600; font-size:0.75rem; color:#78909C; background:#fafafa;">Code</MudTh>
                        <MudTh Style="font-weight:600; font-size:0.75rem; color:#78909C; background:#fafafa;">Name</MudTh>
                        <MudTh Style="font-weight:600; font-size:0.75rem; color:#78909C; background:#fafafa; text-align:right;">Decimals</MudTh>
                        <MudTh Style="font-weight:600; font-size:0.75rem; color:#78909C; background:#fafafa; text-align:center;">Status</MudTh>
                        <MudTh Style="font-weight:600; font-size:0.75rem; color:#78909C; background:#fafafa; width:60px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Code">
                            <MudText Typo="Typo.body2" Style="font-weight:600; color:#1565C0;">@context.Code</MudText>
                        </MudTd>
                        <MudTd DataLabel="Name">
                            <MudText Typo="Typo.body2">@context.Name</MudText>
                        </MudTd>
                        <MudTd DataLabel="Decimals" Style="text-align:right;">
                            <MudText Typo="Typo.body2">@context.DecimalPlaces</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status" Style="text-align:center;">
                            @if(context.IsActive)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Active</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text">Inactive</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@((e) => Delete(context.Id))" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </div>
</div>

<style>
    .page-wrapper {
        padding: 12px 16px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: #f0f4f8;
        min-height: calc(100vh - 80px);
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        background: white;
        border-radius: 12px;
        padding: 14px 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .main-grid {
        display: grid;
        grid-template-columns: 350px 1fr;
        gap: 20px;
        align-items: start;
    }

    /* Stack on smaller screens */
    @@media (max-width: 960px) {
        .main-grid {
            grid-template-columns: 1fr;
        }
    }

    .entry-card, .list-card {
        border-radius: 12px !important;
        overflow: hidden;
    }
</style>

@code {
    private List<Unit> Units = new List<Unit>();
    private Unit currentUnit = new Unit();
    private string searchString = "";
    private bool success;
    private MudForm form;
    private bool _isProcessing = false;

    // References for keyboard navigation
    private MudTextField<string> _codeField;
    private MudTextField<string> _nameField;
    private MudNumericField<int> _decimalField;
    private MudCheckBox<bool> _activeCheck;
    private MudButton _saveButton;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadUnits();
            currentUnit.IsActive = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load units: {ex.Message}", Severity.Error);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _codeField != null)
        {
            // Set focus to the first field on load
            await _codeField.FocusAsync();
        }
    }

    private async Task LoadUnits()
    {
        Units = await UnitService.GetAllUnitsAsync();
    }

    // Keyboard sequence logic to flow downwards
    private async Task HandleKeyDown(KeyboardEventArgs e, object nextControl)
    {
        if (e.Key == "Enter" || e.Key == "NumpadEnter")
        {
            if (nextControl is MudTextField<string> txt)
                await txt.FocusAsync();
            else if (nextControl is MudNumericField<int> num)
                await num.FocusAsync();
        }
    }

    // Since checkbox doesn't handle enter well, we bounce to save button
    private async Task HandleDecimalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "NumpadEnter")
        {
            if (_saveButton != null)
                await _saveButton.FocusAsync();
        }
    }

    private async Task Save()
    {
        if (form == null) return;

        await form.Validate();
        if (!form.IsValid) 
        {
             Snackbar.Add("Please fill required fields", Severity.Warning);
             return;
        }

        _isProcessing = true;
        StateHasChanged();
        await Task.Delay(1);

        try
        {
            if (currentUnit.Id == 0)
            {
                await UnitService.AddUnitAsync(currentUnit);
                Snackbar.Add("Unit saved successfully", Severity.Success);
            }
            else
            {
                await UnitService.UpdateUnitAsync(currentUnit);
                Snackbar.Add("Unit updated successfully", Severity.Success);
            }
            
            await LoadUnits();
            await ResetAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void Edit(Unit unit)
    {
        currentUnit = new Unit 
        { 
            Id = unit.Id, 
            Name = unit.Name, 
            Code = unit.Code, 
            DecimalPlaces = unit.DecimalPlaces, 
            IsActive = unit.IsActive 
        };
        StateHasChanged();
        
        // Return focus to code field when editing starts
        _ = _codeField.FocusAsync();
    }

    private async Task Delete(int id)
    {
        await UnitService.DeleteUnitAsync(id);
        await LoadUnits();
        Snackbar.Add("Unit inactivated", Severity.Success);
        if (currentUnit.Id == id) await ResetAsync();
    }

    private async Task ResetAsync()
    {
        currentUnit = new Unit { IsActive = true };
        if (form != null)
        {
            await form.ResetAsync();
            form.ResetValidation();
        }
        StateHasChanged();
        
        // Always bounce focus back to start
        if (_codeField != null)
        {
            await Task.Delay(50); // Small UI thread delay
            await _codeField.FocusAsync();
        }
    }

    private bool FilterFunc(Unit unit)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (unit.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (unit.Code?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }
}
