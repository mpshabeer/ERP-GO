            await AddLine();
    }

    private async Task AddLine()
    {
        if (tempItem == null || selectedUnitValue == null || tempQty <= 0) return;

        var selectedUnit = tempUnits.First(u => u.Value == selectedUnitValue);
        decimal qtyInBase = tempQty * tempQtyPerBase;

        invoice.SalesInvoiceItems.Add(new InvoiceItemEntity
        {
            ItemId = tempItem.Id,
            Item = tempItem,
            UnitId = selectedUnit.UnitId,
            Unit = allUnits.FirstOrDefault(u => u.Id == selectedUnit.UnitId),
            ItemUnitId = selectedUnit.ItemUnitId, // Save the specific Multi-Unit ID
            ItemUnit = selectedUnit.ItemUnitId.HasValue ? tempItem.ItemUnits.FirstOrDefault(iu => iu.Id == selectedUnit.ItemUnitId) : null, // Set Nav Prop
            Qty = tempQty,
            Rate = tempRate,
            DiscountPercent = tempDiscPercent,
            DiscountAmount = tempDiscAmount,
            Amount = tempAmount,
            QtyPerBaseUnit = tempQtyPerBase,
            QtyInBaseUnit = qtyInBase
        });

        RecalculateTotals();

        // Reset
        tempItem = null; tempItemName = ""; selectedUnitValue = null;
        tempUnits.Clear(); tempQty = 0; tempQtyPerBase = 1; tempRate = 0;
        tempDiscPercent = 0; tempDiscAmount = 0; tempAmount = 0;

        if (_itemSearchField != null)
        {
            await Task.Delay(50);
            await _itemSearchField.FocusAsync();
        }
    }

    private void RemoveLine(InvoiceItemEntity item)
    {
        invoice.SalesInvoiceItems.Remove(item);
        RecalculateTotals();
    }

    private void EditLine(InvoiceItemEntity item)
    {
        _editingItem = item;

        // Load item's data into the entry row
        tempItem = item.Item;
        tempItemName = item.Item != null ? $"{item.Item.ItemCode} - {item.Item.Name}" : "";
        tempQty = item.Qty;
        tempQtyPerBase = item.QtyPerBaseUnit > 0 ? item.QtyPerBaseUnit : 1;
        tempRate = item.Rate;
        tempDiscPercent = item.DiscountPercent;
        tempDiscAmount = item.DiscountAmount;
        tempAmount = item.Amount;

        // Rebuild units list for this item
        tempUnits.Clear();
        if (item.Item?.BaseUnit != null)
            tempUnits.Add(new UnitDisplay
            {
                Value = -item.Item.UnitId,
                UnitId = item.Item.UnitId,
                DisplayName = item.Item.BaseUnit.Name,
                Multiplier = 1,
                ItemUnitId = null,
                UnitRate = item.Item.Rate
            });

        if (item.Item?.ItemUnits != null)
        {
            foreach (var iu in item.Item.ItemUnits)
            {
                var name = iu.Unit?.Name ?? "Unit";
                decimal explicitRate = iu.Rate > 0 ? iu.Rate : (item.Item.Rate * iu.QtyPerBaseUnit);
                tempUnits.Add(new UnitDisplay { Value = iu.Id, UnitId = iu.UnitId, DisplayName = name, Multiplier = iu.QtyPerBaseUnit, ItemUnitId = iu.Id, UnitRate = explicitRate });
            }
        }

        // Try to select the unit that matches the saved row
        // STRICT MATCH: Use ItemUnitId if available
        UnitDisplay matchedUnit = null;

        if (item.ItemUnitId.HasValue)
        {
            matchedUnit = tempUnits.FirstOrDefault(u => u.ItemUnitId == item.ItemUnitId);
        }
        else
        {
            // Fallback for old data or Base Unit (which has null ItemUnitId)
            // If it's Base Unit, we expect ItemUnitId to be null, so check for null ItemUnitId in tempUnits (Value < 0 in our logic usually)
            // But we can check UnitId + ItemUnitId==null
            matchedUnit = tempUnits.FirstOrDefault(u => u.UnitId == item.UnitId && u.ItemUnitId == null);
        }

        selectedUnitValue = matchedUnit?.Value ?? (tempUnits.Any() ? tempUnits.First().Value : (int?)null);

        StateHasChanged();
    }

    private void UpdateLine()
    {
        if (_editingItem == null || tempItem == null || tempQty <= 0) return;

        var selectedUnit = tempUnits.FirstOrDefault(u => u.Value == selectedUnitValue);
        if (selectedUnit == null) return;

        decimal qtyInBase = tempQty * selectedUnit.Multiplier;

        // Update the row in-place
        // Update the row in-place
        _editingItem.ItemId = tempItem.Id;
        _editingItem.Item = tempItem;
        _editingItem.UnitId = selectedUnit.UnitId;
        _editingItem.Unit = allUnits.FirstOrDefault(u => u.Id == selectedUnit.UnitId);
        _editingItem.ItemUnitId = selectedUnit.ItemUnitId; // Update Multi-Unit ID
        _editingItem.ItemUnit = selectedUnit.ItemUnitId.HasValue ? tempItem.ItemUnits.FirstOrDefault(iu => iu.Id == selectedUnit.ItemUnitId) : null; // Set Nav Prop for Grid Display
        _editingItem.Qty = tempQty;
        _editingItem.Rate = tempRate;
        _editingItem.DiscountPercent = tempDiscPercent;
        _editingItem.DiscountAmount = tempDiscAmount;
        _editingItem.Amount = tempAmount;
        _editingItem.QtyPerBaseUnit = tempQtyPerBase;
        _editingItem.QtyInBaseUnit = qtyInBase;

        RecalculateTotals();
        CancelEdit();
    }

    private void CancelEdit()
    {
        _editingItem = null;
        tempItem = null; tempItemName = ""; selectedUnitValue = null;
        tempUnits.Clear(); tempQty = 0; tempQtyPerBase = 1; tempRate = 0;
        tempDiscPercent = 0; tempDiscAmount = 0; tempAmount = 0;
        StateHasChanged();
    }

    private async Task ClearInvoice()
    {
        // Warn if clearing pending changes?
        CancelEdit();
        await InitializeNewInvoiceAsync();
        Snackbar.Add("New invoice ready.", Severity.Info);
    }

    private async Task SaveInvoice()
    {
        await form.Validate();
        if (!success) { Snackbar.Add("Please fix validation errors.", Severity.Warning); return; }
        if (!invoice.SalesInvoiceItems.Any()) { Snackbar.Add("Please add at least one item.", Severity.Warning); return; }

        _isProcessing = true;
        try
        {
            invoice.Date = invoiceDate ?? DateTime.Now;
            if (invoice.Customer == null) { Snackbar.Add("Customer is required.", Severity.Error); return; }
            invoice.CustomerId = invoice.Customer.Id;

            // Detach nav props before save
            // Note: For Update, we might need to be careful with EF not tracking the detached entities if using same context,
            // but here we are sending to API/Service which creates new context.
            invoice.Customer = null;
            foreach (var line in invoice.SalesInvoiceItems)
            {
                line.Item = null;
                line.Unit = null;
            }

            if (invoice.Id == 0)
            {
                await SalesService.CreateInvoice(invoice);
                Snackbar.Add("✅ Invoice saved successfully!", Severity.Success);
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Confirm Update",
                    "This invoice has already been saved. Are you sure you want to update it?",
                    yesText: "Update", cancelText: "Cancel");

                if (result != true)
                {
                    _isProcessing = false;
                    return;
                }

                await SalesService.UpdateInvoice(invoice);
                Snackbar.Add("✅ Invoice updated successfully!", Severity.Success);
            }

            int savedInvoiceId = invoice.Id;
            var savedInvoiceNo = invoice.InvoiceNo;

            // Prompt to print/preview
            bool? wantToPrint = await DialogService.ShowMessageBox(
                "Print Invoice",
                $"Invoice '{savedInvoiceNo}' saved successfully. Would you like to preview/print it now?",
                yesText: "Yes, Print", cancelText: "No");

            // Reload list and reset UI state first
            await InitializeNewInvoiceAsync();
            await LoadList(); // Refresh history

            if (wantToPrint == true && savedInvoiceId > 0)
            {
                // Trigger preview using a dummy entity with just the ID and No (PreviewInvoicePdf only needs these)
                await PreviewInvoicePdf(new InvoiceEntity { Id = savedInvoiceId, InvoiceNo = savedInvoiceNo });
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving invoice: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }
