@page "/sales-invoice"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using ERPGOAPPLICATION.Interfaces
@using ERPGODomain.DTOs
@using ERPGODomain.Entities
@using ERPGoEdition.Shared.Dialogs
@using InvoiceEntity = ERPGODomain.Entities.SalesInvoice
@using InvoiceItemEntity = ERPGODomain.Entities.SalesInvoiceItem
@inject ISalesService SalesService
@inject ICustomerService CustomerService
@inject IItemService ItemService
@inject IUnitService UnitService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IInvoicePdfService InvoicePdfService
@inject IJSRuntime JSRuntime

<div style="height: calc(100vh - 64px); display: flex; flex-direction: column; overflow: hidden;">

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="px-4 py-4" 
             ActivePanelIndex="@_activeTabIndex" ActivePanelIndexChanged="OnTabChanged" KeepPanelsAlive="true">
        
        <!-- TAB 1: NEW / EDIT INVOICE -->
        <MudTabPanel Text="@(invoice.Id == 0 ? "New Invoice" : $"Edit Invoice #{invoice.InvoiceNo}")" Icon="@Icons.Material.Filled.Receipt">
            <div style="height: calc(100vh - 140px); display: flex; flex-direction: column; overflow: hidden;">
                <!-- Scrollable Form Area -->
                <div style="flex: 1; overflow-y: auto; min-height: 0;" class="px-1 py-1">
                    <MudForm @ref="form" @bind-IsValid="@success">

                        <!-- HEADER CARD -->
                        <MudCard Elevation="2" Class="mb-3">
                            <MudCardHeader Class="py-2 px-4" Style="border-bottom: 1px solid #e0e0e0;">
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1">
                                        <b>@(invoice.Id == 0 ? "New Invoice Details" : $"Editing Invoice: {invoice.InvoiceNo}")</b>
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudButton Variant="Variant.Text" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ClearAll" OnClick="ClearInvoice" Size="Size.Small">Clear / New</MudButton>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent Class="py-3 px-4">
                                <MudGrid Spacing="3">
                                    <MudItem xs="6" md="2">
                                        <MudTextField @bind-Value="invoice.InvoiceNo" Label="Invoice No." Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly="true" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudDatePicker Label="Date" @bind-Date="invoiceDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    @if (invoice.PaymentTerms != "Cash")
                                    {
                                        <MudItem xs="6" md="2">
                                            <MudDatePicker Label="Due Date" @bind-Date="invoice.DueDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        </MudItem>
                                    }
                                    <MudItem xs="6" md="2">
                                        <MudSelect T="string" Label="Payment Terms" @bind-Value="invoice.PaymentTerms" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                            <MudSelectItem Value="@("Cash")">Cash</MudSelectItem>
                                            <MudSelectItem Value="@("Credit")">Credit</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudAutocomplete T="Customer" Label="Customer *" @bind-Value="invoice.Customer" SearchFunc="@SearchCustomers"
                                                         ToStringFunc="@(c => c == null ? null : c.Name)"
                                                         Required="true" RequiredError="Customer is required."
                                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         AdornmentIcon="@Icons.Material.Filled.Search"
                                                         AnchorOrigin="Origin.BottomCenter" Dense="true"
                                                         Clearable="true" ResetValueOnEmptyText="true">
                                            <ItemTemplate Context="e">
                                                <div class="d-flex flex-column pa-1">
                                                    <MudText Typo="Typo.body2"><b>@e.Name</b></MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@e.Code &bull; @e.Mobile</MudText>
                                                </div>
                                            </ItemTemplate>
                                        </MudAutocomplete>
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>

                        <!-- ENTRY ROW -->
                        <MudCard Elevation="2" Class="mb-3">
                            <MudCardContent Class="py-2 px-4">
                                <MudGrid Spacing="2" Class="align-center">
                                    <MudItem xs="12" md="3">
                                        <MudTextField @ref="_itemSearchField" Value="@tempItemName" Label="Item" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                                      OnAdornmentClick="OpenItemSearch" Placeholder="Click 🔍 to search..." 
                                                      OnKeyDown="OnItemSearchKeyDown" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudSelect T="int?" Label="Unit" Value="@selectedUnitValue" ValueChanged="@OnUnitChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                            @foreach(var u in tempUnits)
                                            {
                                                <MudSelectItem Value="@((int?)u.Value)">@u.DisplayName</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6" md="1">
                                        <MudNumericField @ref="_qtyField" @bind-Value="tempQty" Label="Qty" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         HideSpinButtons="true" Min="0" TextChanged="CalculateAmount" OnKeyDown="OnQtyKeyDown" />
                                    </MudItem>
                                    <MudItem xs="6" md="1">
                                        <MudNumericField @bind-Value="tempQtyPerBase" Label="Qty/Base" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         HideSpinButtons="true" Min="0" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudNumericField @ref="_rateField" @bind-Value="tempRate" Label="Rate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         HideSpinButtons="true" Min="0" Format="N2" TextChanged="CalculateAmount" OnKeyDown="OnRateKeyDown" />
                                    </MudItem>
                                    <MudItem xs="6" md="1">
                                        <MudNumericField @ref="_discField" @bind-Value="tempDiscPercent" Label="Disc %" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         HideSpinButtons="true" Min="0" Max="100" TextChanged="@(() => OnDiscPercentChanged(tempDiscPercent))" OnKeyDown="OnDiscKeyDown" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudTextField Value="@tempAmount" Label="Net Amount" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" Format="N2" />
                                    </MudItem>
                                    <MudItem xs="6" md="1">
                                        @if (_editingItem == null)
                                        {
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddLine" FullWidth="true"
                                                       Disabled="@(tempItem == null || tempQty <= 0)"
                                                       StartIcon="@Icons.Material.Filled.Add">Add</MudButton>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column gap-1">
                                                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="UpdateLine" FullWidth="true"
                                                           Disabled="@(tempItem == null || tempQty <= 0)"
                                                           StartIcon="@Icons.Material.Filled.Save"
                                                           Style="font-weight:bold;">Update</MudButton>
                                                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelEdit" FullWidth="true"
                                                           Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.Cancel">Cancel</MudButton>
                                            </div>
                                        }
                                    </MudItem>
                                </MudGrid>
                                @if (tempItem != null)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-1" Color="@(tempItem.CurrentStock > 0 ? Color.Success : Color.Warning)">
                                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Class="mr-1" />
                                        Available Stock: <b>@tempItem.CurrentStock</b> (base units)
                                    </MudText>
                                }
                            </MudCardContent>
                        </MudCard>

                        <!-- ITEM GRID -->
                        @if (_editingItem != null)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2" Icon="@Icons.Material.Filled.Edit">
                                Editing row: <b>@_editingItem.Item?.Name</b> — Modify fields above and click <b>Update</b>, or click <b>Cancel</b> to discard.
                            </MudAlert>
                        }
                        <MudTable Items="@invoice.SalesInvoiceItems" Hover="true" Dense="true" Bordered="true" Striped="true" Elevation="2" Class="mb-3">
                            <HeaderContent>
                                <MudTh Style="width: 50px;">#</MudTh>
                                <MudTh Style="width: 40%;">Item</MudTh>
                                <MudTh>Unit</MudTh>
                                <MudTh Style="text-align:right;">Qty</MudTh>
                                <MudTh Style="text-align:right;">Qty/Base</MudTh>
                                <MudTh Style="text-align:right;">Rate</MudTh>
                                <MudTh Style="text-align:right;">Disc %</MudTh>
                                <MudTh Style="text-align:right;">Amount</MudTh>
                                <MudTh Style="width:80px; text-align:center;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{
                                    bool isEditing = _editingItem == context;
                                    string rowBg = isEditing ? "background-color: #fff9e6; font-weight: bold;" : "";
                                    var itemsList = invoice.SalesInvoiceItems.ToList();
                                    int rowIndex = itemsList.IndexOf(context) + 1;
                                }
                                <MudTd Style="@rowBg">@rowIndex</MudTd>
                                <MudTd DataLabel="Item" Style="@rowBg">
                                    <div class="d-flex align-center gap-1">
                                        @if (isEditing)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning" />
                                        }
                                        <div>
                                            <MudText Typo="Typo.body2"><b>@context.Item?.Name</b></MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item?.ItemCode</MudText>
                                        </div>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Unit" Style="@rowBg">@((context.ItemUnit?.Unit != null) ? context.ItemUnit.Unit.Name : context.Unit?.Name)</MudTd>
                                <MudTd DataLabel="Qty" Style="@($"text-align:right; {rowBg}")">@context.Qty.ToString("N2")</MudTd>
                                <MudTd DataLabel="Qty/Base" Style="@($"text-align:right; {rowBg}")">@context.QtyPerBaseUnit.ToString("N2")</MudTd>
                                <MudTd DataLabel="Rate" Style="@($"text-align:right; {rowBg}")">@context.Rate.ToString("N2")</MudTd>
                                <MudTd DataLabel="Disc %" Style="@($"text-align:right; {rowBg}")">@context.DiscountPercent.ToString("0.##")%</MudTd>
                                <MudTd DataLabel="Amount" Style="@($"text-align:right; {rowBg}")"><b>@context.Amount.ToString("N2")</b></MudTd>
                                <MudTd Style="@($"text-align:center; {rowBg}")">
                                    <MudTooltip Text="Edit this row">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(() => EditLine(context))"
                                                       Disabled="@(_editingItem != null && _editingItem != context)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete this row">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                       OnClick="@(() => RemoveLine(context))"
                                                       Disabled="@(_editingItem == context)" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                            <FooterContent>
                                <MudTfootRow Class="total-row">
                                    <MudTd colspan="6" Style="text-align:right; font-weight:bold;">Subtotal:</MudTd>
                                    <MudTd Style="text-align:right; font-weight:bold;">@invoice.SalesInvoiceItems.Sum(x => x.Amount).ToString("N2")</MudTd>
                                    <MudTd></MudTd>
                                </MudTfootRow>
                            </FooterContent>
                        </MudTable>

                        <!-- TOTALS + NOTES -->
                        <MudCard Elevation="2" Class="mb-3">
                            <MudCardContent Class="py-3 px-4">
                                <MudGrid Spacing="3">
                                    <!-- Left: Notes -->
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="invoice.Notes" Label="Notes / Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                                    </MudItem>

                                    <!-- Right: Totals Summary -->
                                    <MudItem xs="12" md="6">
                                        <MudPaper Outlined="true" Class="pa-0" Style="border-radius: 8px; overflow: hidden;">
                                            <div class="d-flex justify-space-between align-center px-4 py-2" style="background: #fafafa; border-bottom: 1px solid #e0e0e0;">
                                                <MudText Typo="Typo.body2" Style="color: #555;">Subtotal</MudText>
                                                <MudText Typo="Typo.body1"><b>@invoice.SubTotal.ToString("N2")</b></MudText>
                                            </div>
                                            <div class="d-flex justify-space-between align-center px-4 py-2" style="background: #fff8f8; border-bottom: 1px solid #e0e0e0;">
                                                <div class="d-flex align-center" style="gap: 8px;">
                                                    <MudText Typo="Typo.body2" Style="color: #555; min-width: 60px;">Discount</MudText>
                                                    <MudNumericField @bind-Value="invoice.DiscountPercent"
                                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                     HideSpinButtons="true" Min="0" Max="100"
                                                                     Adornment="Adornment.End" AdornmentText="%"
                                                                     Style="width: 100px;"
                                                                     TextChanged="RecalculateTotals" />
                                                </div>
                                                <MudText Typo="Typo.body1" Color="Color.Error"><b>- @invoice.DiscountAmount.ToString("N2")</b></MudText>
                                            </div>
                                            <div class="d-flex justify-space-between align-center px-4 py-2" style="background: #f6fff6; border-bottom: 1px solid #e0e0e0;">
                                                <div class="d-flex align-center" style="gap: 8px;">
                                                    <MudText Typo="Typo.body2" Style="color: #555; min-width: 60px;">Tax / GST</MudText>
                                                    <MudNumericField @bind-Value="invoice.TaxPercent"
                                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                     HideSpinButtons="true" Min="0" Max="100"
                                                                     Adornment="Adornment.End" AdornmentText="%"
                                                                     Style="width: 100px;"
                                                                     TextChanged="RecalculateTotals" />
                                                </div>
                                                <MudText Typo="Typo.body1" Color="Color.Success"><b>+ @invoice.TaxAmount.ToString("N2")</b></MudText>
                                            </div>
                                            <div class="d-flex justify-space-between align-center px-4 py-3" style="background: #1565C0;">
                                                <MudText Typo="Typo.subtitle1" Style="color: white; font-weight: 700; letter-spacing: 0.04em;">GRAND TOTAL</MudText>
                                                <MudText Typo="Typo.h6" Style="color: white; font-weight: 700;">@invoice.TotalAmount.ToString("N2")</MudText>
                                            </div>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>

                    </MudForm>
                </div>

                <!-- FIXED FOOTER -->
                <div style="flex: 0 0 auto; border-top: 2px solid #1976d2;" class="px-4 py-2">
                    <div class="d-flex justify-space-between align-center">
                        <div class="d-flex align-center gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.caption">Invoice Total</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Primary"><b>@invoice.TotalAmount.ToString("N2")</b></MudText>
                            </div>
                            @if (invoice.SalesInvoiceItems.Count > 0)
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">@invoice.SalesInvoiceItems.Count item(s)</MudChip>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ClearInvoice"
                                       StartIcon="@Icons.Material.Filled.ClearAll" Size="Size.Large">
                                Clear / New
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveInvoice"
                                       Disabled="_isProcessing" StartIcon="@Icons.Material.Filled.Save" Size="Size.Large"
                                       Style="min-width: 160px; font-weight: bold;">
                                @if (_isProcessing)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <span>@(invoice.Id == 0 ? "SAVE INVOICE" : "UPDATE INVOICE")</span>
                                }
                            </MudButton>
                        </div>
                    </div>
                </div>
            </div>
        </MudTabPanel>

        <!-- TAB 2: INVOICE HISTORY -->
        <MudTabPanel Text="Invoice History" Icon="@Icons.Material.Filled.History">
            <div style="height: calc(100vh - 140px); display: flex; flex-direction: column; overflow: hidden;">
                <!-- Search / Filter Card -->
                <div style="flex: 0 0 auto;" class="px-1 py-1">
                    <MudCard Elevation="2">
                        <MudCardContent Class="py-2 px-4">
                            <MudGrid Spacing="2" Class="align-center">
                                <MudItem xs="12" sm="3">
                                    <MudTextField @bind-Value="listFilter.InvoiceNo" Label="Invoice No." Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Tag" Placeholder="e.g. INV001"
                                                  @onkeydown="OnSearchKeyDown" />
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudTextField @bind-Value="listFilter.CustomerName" Label="Customer" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" Placeholder="Search customer..."
                                                  @onkeydown="OnSearchKeyDown" />
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudDatePicker @bind-Date="_listDateFrom" Label="From Date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudDatePicker @bind-Date="_listDateTo" Label="To Date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="2" Class="d-flex gap-2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search"
                                               OnClick="LoadList" FullWidth="true" Size="Size.Small">Search</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ClearAll"
                                               OnClick="ClearListFilter" Size="Size.Small">Clear</MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </div>

                <!-- Results Summary -->
                <div style="flex: 0 0 auto;" class="px-4 pb-1 d-flex justify-space-between align-center">
                    @if (!_listLoading && _listResult != null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Showing <b>@(_listResult.Items.Count)</b> of <b>@_listResult.TotalCount</b> invoices
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Page <b>@_listResult.Page</b> of <b>@_listResult.TotalPages</b>
                        </MudText>
                    }
                </div>

                <!-- List Table -->
                <div style="flex: 1; overflow-y: auto; min-height: 0;" class="px-1">
                    @if (_listLoading)
                    {
                        <div class="d-flex justify-center align-center" style="height: 200px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                    else if (_listResult?.Items.Count == 0)
                    {
                        <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center pa-8" Style="min-height: 200px; border: 2px dashed #e0e0e0;">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Tertiary" />
                            <MudText Typo="Typo.body1" Class="mt-2" Color="Color.Tertiary">No invoices found</MudText>
                        </MudPaper>
                    }
                    else if (_listResult != null)
                    {
                        <MudTable Items="@_listResult.Items" Hover="true" Dense="true" Bordered="true" Striped="true" Elevation="2" FixedHeader="true" Height="100%">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Invoice No.</MudTh>
                                <MudTh>Date</MudTh>
                                <MudTh>Customer</MudTh>
                                <MudTh Style="text-align:right;">Total</MudTh>
                                <MudTh Style="width: 100px; text-align:center;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{
                                    int rowNum = _listResult.Items.IndexOf(context) + 1 + ((_listResult.Page - 1) * _listResult.PageSize);
                                }
                                <MudTd>@rowNum</MudTd>
                                <MudTd>
                                    <MudLink Color="Color.Primary" Style="font-weight: bold; cursor: pointer;" OnClick="@(() => LoadInvoiceForEdit(context))">
                                        @context.InvoiceNo
                                    </MudLink>
                                </MudTd>
                                <MudTd>@context.Date.ToString("dd-MMM-yyyy")</MudTd>
                                <MudTd>@context.Customer?.Name</MudTd>
                                <MudTd Style="text-align:right; font-weight: bold; color: #1976d2;">@context.TotalAmount.ToString("N2")</MudTd>
                                 <MudTd Style="text-align:center;">
                                    <MudTooltip Text="Edit Invoice">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="@(() => LoadInvoiceForEdit(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Preview PDF">
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                                       OnClick="@(async () => await PreviewInvoicePdf(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Download PDF">
                                        <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(async () => await DownloadInvoicePdf(context))" />
                                    </MudTooltip>
                                 </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager />
                            </PagerContent>
                        </MudTable>
                        
                         <!-- Pagination Footer Custom -->
                        @if (_listResult.TotalPages > 0)
                        {
                            <div style="flex: 0 0 auto; border-top: 1px solid #e0e0e0;" class="px-4 py-2 d-flex justify-center align-center gap-2">
                                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" Disabled="@(_listResult.Page == 1)" OnClick="@(() => GoToPage(1))" />
                                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Disabled="@(_listResult.Page == 1)" OnClick="@(() => GoToPage(_listResult.Page - 1))" />
                                <MudText Typo="Typo.caption">Page @_listResult.Page of @_listResult.TotalPages</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@(_listResult.Page >= _listResult.TotalPages)" OnClick="@(() => GoToPage(_listResult.Page + 1))" />
                                <MudIconButton Icon="@Icons.Material.Filled.LastPage" Disabled="@(_listResult.Page >= _listResult.TotalPages)" OnClick="@(() => GoToPage(_listResult.TotalPages))" />
                            </div>
                        }
                    }
                </div>
            </div>
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private int _activeTabIndex = 0;

    // ────────── NEW / EDIT INVOICE STATE ──────────
    private InvoiceEntity invoice = new InvoiceEntity();
    private DateTime? invoiceDate = DateTime.Now;
    private bool success;
    private MudForm form;
    private bool _isProcessing = false;
    private InvoiceItemEntity? _editingItem = null; 

    // Cache
    private List<Customer> customers = new List<Customer>();
    private List<Unit> allUnits = new List<Unit>();

    // Entry Row Variables
    private Item? tempItem;
    private string tempItemName = "";
    private int? selectedUnitValue;
    private List<UnitDisplay> tempUnits = new List<UnitDisplay>();
    private decimal tempQty = 0;
    private decimal tempQtyPerBase = 1;
    private decimal tempRate = 0;
    private decimal tempDiscPercent = 0;
    private decimal tempDiscAmount = 0;
    private decimal tempAmount = 0;

    private MudTextField<string> _itemSearchField;
    private MudNumericField<decimal> _qtyField;
    private MudNumericField<decimal> _rateField;
    private MudNumericField<decimal> _discField;
    private MudButton _addButton;

    public class UnitDisplay
    {
        public int Value { get; set; }
        public int UnitId { get; set; }
        public string DisplayName { get; set; }
        public decimal Multiplier { get; set; }
        public int? ItemUnitId { get; set; }
        public decimal UnitRate { get; set; }
    }

    // ────────── LIST STATE ──────────
    private InvoiceSearchRequest listFilter = new() { PageSize = 15 };
    private DateTime? _listDateFrom;
    private DateTime? _listDateTo;
    private PagedResult<InvoiceEntity>? _listResult;
    private bool _listLoading = false;

    // ────────── LIFECYCLE ──────────

    protected override async Task OnInitializedAsync()
    {
        await LoadCacheData();
        await InitializeNewInvoiceAsync();
        // Don't load list immediately, wait for tab switch or user action? 
        // Or load it now. Let's load it now.
        await LoadList(); 
    }

    private void OnTabChanged(int index)
    {
        _activeTabIndex = index;
    }

    private async Task InitializeNewInvoiceAsync()
    {
        try
        {
            invoice = new InvoiceEntity(); // Reset ID to 0
            invoice.InvoiceNo = await SalesService.GetNextInvoiceNumber();
        }
        catch
        {
            invoice.InvoiceNo = $"INV-{DateTime.Now:yyyyMMddHHmmss}";
        }

        invoice.PaymentTerms = "Cash";
        invoiceDate = DateTime.Now;
        invoice.DueDate = DateTime.Now;
        
        // Default Customer
        if (customers.Any())
        {
            var defaultCustomer = customers.FirstOrDefault(c => c.Code == "C1000") 
                               ?? customers.FirstOrDefault(c => c.Name.Contains("Cash", StringComparison.OrdinalIgnoreCase));
            
            if (defaultCustomer != null)
            {
                invoice.Customer = defaultCustomer;
                invoice.CustomerId = defaultCustomer.Id;
            }
        }

        invoice.SalesInvoiceItems = new List<InvoiceItemEntity>();
        
        // Reset Entry
        CancelEdit();
    }

    private async Task LoadCacheData()
    {
        try
        {
            var t1 = CustomerService.GetAllCustomersAsync();
            var t2 = UnitService.GetAllUnitsAsync();
            await Task.WhenAll(t1, t2);
            customers = t1.Result;
            allUnits = t2.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
    }

    // ────────── LIST METHODS ──────────

    private async Task LoadList()
    {
        _listLoading = true;
        try
        {
            listFilter.DateFrom = _listDateFrom;
            listFilter.DateTo = _listDateTo;
            _listResult = await SalesService.GetInvoicesAsync(listFilter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading list: {ex.Message}", Severity.Error);
        }
        finally
        {
            _listLoading = false;
        }
    }

    private async Task ClearListFilter()
    {
        listFilter = new InvoiceSearchRequest { PageSize = listFilter.PageSize };
        _listDateFrom = null;
        _listDateTo = null;
        await LoadList();
    }

    private async Task GoToPage(int page)
    {
        listFilter.Page = page;
        await LoadList();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            listFilter.Page = 1;
            await LoadList();
        }
    }

    // ────────── PDF PREVIEW & DOWNLOAD ──────────

    private bool _isPdfLoading = false;

    private async Task PreviewInvoicePdf(InvoiceEntity inv)
    {
        if (_isPdfLoading) return;
        _isPdfLoading = true;
        try
        {
            var bytes = await InvoicePdfService.GenerateSalesInvoicePdfAsync(inv.Id);
            var parameters = new DialogParameters { ["PdfBytes"] = bytes };
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
            DialogService.Show<Dialogs.PdfPreviewDialog>($"Preview Invoice - {inv.InvoiceNo}", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating preview: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPdfLoading = false;
        }
    }

    private async Task DownloadInvoicePdf(InvoiceEntity inv)
    {
        if (_isPdfLoading) return;
        _isPdfLoading = true;
        Snackbar.Add($"Generating PDF for {inv.InvoiceNo}…", Severity.Info);
        try
        {
            var bytes = await InvoicePdfService.GenerateSalesInvoicePdfAsync(inv.Id);
            await JSRuntime.InvokeVoidAsync(
                "downloadFileFromBytes",
                $"Invoice_{inv.InvoiceNo}.pdf",
                "application/pdf",
                bytes);
            Snackbar.Add("PDF downloaded!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating PDF: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPdfLoading = false;
        }
    }

    // ────────── LOAD FOR EDIT LOGIC ──────────


    private async Task LoadInvoiceForEdit(InvoiceEntity selectedInvoice)
    {
        // 1. Check if current invoice has unsaved changes (has items and ID=0 (new) or ID!=0 (editing another))
        if (invoice.SalesInvoiceItems.Any())
        {
            bool? result = await DialogService.ShowMessageBox(
                "Unsaved Changes",
                "You have unsaved changes in the current invoice. Loading another invoice will discard these changes. Continue?",
                yesText: "Discard & Load", cancelText: "Cancel");

            if (result != true) return;
        }

        try
        {
            // 2. Clone the selected invoice to avoid reference issues with the list
            // Or re-fetch from DB to ensure we have all fields/items if list is partial
             // Since list items might not have all details if projection was used, but currently it's full entity.
            // However, to be safe and get fresh state, let's assume usage of list object is okay for now as it includes items.
            // We need a DEEP COPY to avoid modifying the list item directly in UI before save.
            
            // Re-fetching is safer. Since we don't have GetById, we can search by ID or just use the object if untracked.
            // Using JSON serialization for deep copy is a quick hack, or manual mapping.
            // Let's manually map for safety.
            
            var newInv = new InvoiceEntity 
            {
                Id = selectedInvoice.Id,
                InvoiceNo = selectedInvoice.InvoiceNo,
                Date = selectedInvoice.Date,
                DueDate = selectedInvoice.DueDate,
                PaymentTerms = selectedInvoice.PaymentTerms,
                CustomerId = selectedInvoice.CustomerId,
                Customer = customers.FirstOrDefault(c => c.Id == selectedInvoice.CustomerId), // Link to cached customer
                Notes = selectedInvoice.Notes,
                SubTotal = selectedInvoice.SubTotal,
                DiscountPercent = selectedInvoice.DiscountPercent,
                DiscountAmount = selectedInvoice.DiscountAmount,
                TaxPercent = selectedInvoice.TaxPercent,
                TaxAmount = selectedInvoice.TaxAmount,
                TotalAmount = selectedInvoice.TotalAmount,
                SalesInvoiceItems = new List<InvoiceItemEntity>()
            };

            if (selectedInvoice.SalesInvoiceItems != null)
            {
                foreach (var item in selectedInvoice.SalesInvoiceItems)
                {
                    newInv.SalesInvoiceItems.Add(new InvoiceItemEntity
                    {
                        Id = item.Id, // Keep ID for update
                        SalesInvoiceId = item.SalesInvoiceId,
                        ItemId = item.ItemId,
                        Item = item.Item, // Reference is fine
                        UnitId = item.UnitId,
                        Unit = item.Unit,
                        Qty = item.Qty,
                        Rate = item.Rate,
                        DiscountPercent = item.DiscountPercent,
                        DiscountAmount = item.DiscountAmount,
                        Amount = item.Amount,
                        QtyPerBaseUnit = item.QtyPerBaseUnit,
                        QtyInBaseUnit = item.QtyInBaseUnit
                    });
                }
            }

            // 3. Set to active
            invoice = newInv;
            invoiceDate = invoice.Date; // Bind date
            
            // 4. Switch Tab
            _activeTabIndex = 0;
            CancelEdit(); // Reset entry row
            StateHasChanged();

            Snackbar.Add($"Invoice {invoice.InvoiceNo} loaded for editing.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading invoice: {ex.Message}", Severity.Error);
        }
    }

    // ────────── INVOICE ENTRY METHODS ──────────

    private async Task<IEnumerable<Customer>> SearchCustomers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return customers;
        return customers.Where(x =>
            x.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase) ||
            x.Code.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task OpenItemSearch()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<ItemSearchDialog>("Search Item", options);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is Item item)
        {
            await OnItemSelected(item);
            if (_qtyField != null)
                await Task.Delay(50); // slight delay to ensure UI updates
                await _qtyField.FocusAsync();
        }
        else
        {
            if (_itemSearchField != null)
                await _itemSearchField.FocusAsync();
        }
    }

    private async Task OnItemSelected(Item item)
    {
        tempItem = item;
        tempItemName = $"{item.ItemCode} - {item.Name}";
        tempQty = 1;
        tempQtyPerBase = 1;
        tempRate = item.Rate;
        tempDiscPercent = 0;
        tempDiscAmount = 0;

        tempUnits.Clear();
        if (item.BaseUnit != null)
            tempUnits.Add(new UnitDisplay { Value = -item.UnitId, UnitId = item.UnitId, DisplayName = item.BaseUnit.Name, Multiplier = 1, ItemUnitId = null, UnitRate = item.Rate });

        if (item.ItemUnits != null)
        {
            foreach (var iu in item.ItemUnits)
            {
                var name = iu.Unit?.Name ?? "Unit";
                decimal explicitRate = iu.Rate > 0 ? iu.Rate : (item.Rate * iu.QtyPerBaseUnit);
                tempUnits.Add(new UnitDisplay { Value = iu.Id, UnitId = iu.UnitId, DisplayName = name, Multiplier = iu.QtyPerBaseUnit, ItemUnitId = iu.Id, UnitRate = explicitRate });
            }
        }

        if (tempUnits.Any())
        {
            var baseUnit = tempUnits.FirstOrDefault(u => u.Value < 0);
            selectedUnitValue = baseUnit?.Value ?? tempUnits.First().Value;
            await OnUnitChanged(selectedUnitValue);
            StateHasChanged();
        }
    }

    private async Task OnUnitChanged(int? value)
    {
        selectedUnitValue = value;
        if (tempItem == null || value == null) return;
        var selectedUnit = tempUnits.FirstOrDefault(u => u.Value == value);
        if (selectedUnit != null)
        {
            tempQtyPerBase = selectedUnit.Multiplier;
            tempRate = selectedUnit.UnitRate;
        }
        CalculateAmount();
    }

    private void OnDiscPercentChanged(decimal percent)
    {
        var gross = tempQty * tempRate;
        tempDiscAmount = gross * (percent / 100);
        CalculateAmount();
    }

    private void CalculateAmount()
    {
        var gross = tempQty * tempRate;
        tempDiscAmount = gross * (tempDiscPercent / 100);
        tempAmount = gross - tempDiscAmount;
    }

    private void RecalculateTotals()
    {
        invoice.SubTotal = invoice.SalesInvoiceItems.Sum(x => x.Amount);
        invoice.DiscountAmount = invoice.SubTotal * (invoice.DiscountPercent / 100);
        invoice.TaxAmount = (invoice.SubTotal - invoice.DiscountAmount) * (invoice.TaxPercent / 100);
        invoice.TotalAmount = invoice.SubTotal - invoice.DiscountAmount + invoice.TaxAmount;
    }

    private void RecalculateTotals(decimal value) => RecalculateTotals();

