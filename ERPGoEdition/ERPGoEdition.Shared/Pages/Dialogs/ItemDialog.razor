@using ERPGODomain.Entities
@using ERPGOAPPLICATION.Interfaces
@using MudBlazor
@inject IUnitService UnitService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTabs Bounded="true">
            <!-- General Info Tab -->
            <MudTabPanel Text="General Info">
                <MudGrid Class="mt-2">
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Item Name" @bind-Value="Item.Name" Required="true" RequiredError="Name is required." Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Item Code" @bind-Value="Item.ItemCode" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Barcode" @bind-Value="Item.Barcode" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int" Label="Base Unit" @bind-Value="Item.UnitId" Required="true" RequiredError="Base Unit is required." Variant="Variant.Outlined" Margin="Margin.Dense">
                            @foreach (var unit in Units.Where(u => u.IsActive || u.Id == Item.UnitId).DistinctBy(u => u.Id))
                            {
                                <MudSelectItem Value="@unit.Id">@unit.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal" Label="Selling Rate (Base)" @bind-Value="Item.Rate" Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal" Label="Purchase Rate" @bind-Value="Item.PurchaseRate" Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal" Label="Wholesale Rate" @bind-Value="Item.WholesaleRate" Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudCheckBox T="bool" Label="Multi-Unit Item" @bind-Value="Item.IsMultiUnit" Color="Color.Primary" />
                        <MudCheckBox T="bool" Label="Active" @bind-Value="Item.IsActive" Color="Color.Success" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <!-- Multi-Unit Tab -->
            <MudTabPanel Text="Multi-Units" Disabled="!Item.IsMultiUnit">
                <MudStack Row="true" Class="mt-2 mb-2 align-center">
                    <MudText Typo="Typo.subtitle2"><b>Packings / Units</b></MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddUnitRow">Add Packing</MudButton>
                </MudStack>
                
                <MudTable Items="@Item.ItemUnits" Hover="true" Dense="true" Bordered="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh Style="padding: 2px 8px;">Unit</MudTh>
                        <MudTh Style="padding: 2px 8px; text-align:center">Qty / Base Unit</MudTh>
                        <MudTh Style="padding: 2px 8px; text-align:center">Sales Rate</MudTh>
                        <MudTh Style="padding: 2px 8px; text-align:center">Purchase Rate</MudTh>
                        <MudTh Style="width:36px; padding: 2px 4px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @{
                            var isBaseRow = context.UnitId == Item.UnitId && Item.ItemUnits.ToList().IndexOf(context) == 0;
                        }
                        <MudTd DataLabel="Unit" Style="padding: 2px 4px;">
                            @if (isBaseRow)
                            {
                                <MudText Style="font-size:0.8rem; font-weight:600;">@(Units.FirstOrDefault(u => u.Id == context.UnitId)?.Name ?? "—") <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="font-size:0.65rem; height:16px; padding:0 4px;">Base</MudChip></MudText>
                            }
                            else
                            {
                                <MudSelect T="int" Value="context.UnitId" ValueChanged="@((int v) => OnUnitChanged(context, v))" Margin="Margin.None" Variant="Variant.Text" Style="font-size: 0.8rem" DisableUnderLine="true" Dense="true">
                                    @foreach (var unit in Units.Where(u => u.Id == context.UnitId || (u.IsActive && !Item.ItemUnits.Any(iu => iu.UnitId == u.Id))).DistinctBy(u => u.Id))
                                    {
                                        <MudSelectItem Value="@unit.Id">@unit.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </MudTd>
                        <MudTd DataLabel="Qty/Base" Style="padding: 0px 8px 0px 0px; text-align:center;">
                            <MudNumericField @bind-Value="context.QtyPerBaseUnit" Margin="Margin.None" Variant="Variant.Text" DisableUnderLine="true" Disabled="@isBaseRow" HideSpinButtons="true" InputStyle="text-align: center;" />
                        </MudTd>
                        <MudTd DataLabel="Sales Rate" Style="padding: 0px 8px 0px 0px; text-align:center;">
                            <MudNumericField @bind-Value="context.Rate" Margin="Margin.None" Variant="Variant.Text" DisableUnderLine="true" HideSpinButtons="true" InputStyle="text-align: center;" />
                        </MudTd>
                        <MudTd DataLabel="Purchase Rate" Style="padding: 0px 8px 0px 0px; text-align:center;">
                            <MudNumericField @bind-Value="context.PurchaseRate" Margin="Margin.None" Variant="Variant.Text" DisableUnderLine="true" HideSpinButtons="true" InputStyle="text-align: center;" />
                        </MudTd>
                        <MudTd Style="padding: 0px; text-align:center;">
                            @if (!isBaseRow)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveUnitRow(context))" Size="Size.Small" Color="Color.Error" />
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public Item Item { get; set; } = new Item();
    
    private List<Unit> Units = new List<Unit>();

    protected override async Task OnInitializedAsync()
    {
        Units = await UnitService.GetAllUnitsIncludeInactiveAsync();
        if (Item.ItemUnits == null) Item.ItemUnits = new List<ItemUnit>();
        
        // Auto-add base unit row if multi-unit and no rows yet
        if (Item.IsMultiUnit && Item.UnitId > 0)
            EnsureBaseUnitRow();
    }

    private void EnsureBaseUnitRow()
    {
        if (!Item.ItemUnits.Any(iu => iu.UnitId == Item.UnitId))
        {
            var list = Item.ItemUnits.ToList();
            list.Insert(0, new ItemUnit
            {
                ItemId = Item.Id,
                UnitId = Item.UnitId,
                QtyPerBaseUnit = 1,
                Rate = Item.Rate,
                PurchaseRate = Item.PurchaseRate
            });
            Item.ItemUnits = list;
        }
    }

    private void AddUnitRow()
    {
        var usedIds = Item.ItemUnits.Select(iu => iu.UnitId).ToHashSet();
        var next = Units.FirstOrDefault(u => u.IsActive && !usedIds.Contains(u.Id));
        if (next == null)
        {
            Snackbar.Add("All available units have been added.", Severity.Warning);
            return;
        }
        Item.ItemUnits.Add(new ItemUnit { ItemId = Item.Id, UnitId = next.Id, QtyPerBaseUnit = 1 });
    }

    private void RemoveUnitRow(ItemUnit unit)
    {
        if (Item.ItemUnits.ToList().IndexOf(unit) == 0 && unit.UnitId == Item.UnitId)
        {
            Snackbar.Add("Cannot remove the base unit row.", Severity.Warning);
            return;
        }
        Item.ItemUnits.Remove(unit);
    }

    private void OnUnitChanged(ItemUnit row, int newUnitId)
    {
        if (Item.ItemUnits.Any(iu => iu != row && iu.UnitId == newUnitId))
        {
            Snackbar.Add("This unit is already added.", Severity.Warning);
            return;
        }
        row.UnitId = newUnitId;
    }

    void Submit()
    {
        if (string.IsNullOrWhiteSpace(Item.Name) || Item.UnitId == 0)
        {
            Snackbar.Add("Name and Base Unit are required.", Severity.Warning);
            return; 
        }
        
        var selectedUnit = Units.FirstOrDefault(u => u.Id == Item.UnitId);
        if (selectedUnit != null) Item.BaseUnit = selectedUnit;
        
        foreach (var iu in Item.ItemUnits)
        {
            var u = Units.FirstOrDefault(x => x.Id == iu.UnitId);
            if (u != null) iu.Unit = u;
        }

        MudDialog.Close(DialogResult.Ok(Item));
    }

    void Cancel() => MudDialog.Cancel();
}
