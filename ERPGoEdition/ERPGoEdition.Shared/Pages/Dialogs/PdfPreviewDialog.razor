<MudDialog>
    <DialogContent>
        @if (PdfBytes != null && PdfBytes.Length > 0)
        {
            var base64 = Convert.ToBase64String(PdfBytes);
            var src = $"data:application/pdf;base64,{base64}";
            <div style="height: 75vh; width: 100%;">
                <embed src="@src" style="width: 100%; height: 100%;" type="application/pdf" />
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Error">PDF data is missing or empty.</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public byte[]? PdfBytes { get; set; }

    private void Close()
    {
        MudDialog.Cancel();
    }
}
